# APP_NAME = resource prefix; KUBE_NAMESPACE = namespace. Defaults are both "app".
# Optional MinIO module. bootstrap.sh creates this secret when MinIO is selected.
# For manual setup, render/apply this before applying k8s/minio/*.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: ${APP_NAME}-minio
  namespace: ${KUBE_NAMESPACE}
type: Opaque
stringData:
  root-user: "CHANGE_ME"       # min. 3 chars
  root-password: "CHANGE_ME"   # min. 8 chars
