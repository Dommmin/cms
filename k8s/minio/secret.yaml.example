# app = the namespace / app prefix you chose during bootstrap (e.g. "app")
# (bootstrap.sh handles this automatically)
apiVersion: v1
kind: Secret
metadata:
  name: app-minio   # replace app with your namespace (e.g. app)
  namespace: app    # replace app with your namespace (e.g. app)
type: Opaque
stringData:
  root-user: "CHANGE_ME"       # min. 3 chars
  root-password: "CHANGE_ME"   # min. 8 chars
