# APP_NAME = the namespace / app prefix you chose during bootstrap (e.g. "app")
# (bootstrap.sh handles this automatically)
apiVersion: v1
kind: Secret
metadata:
  name: APP_NAME-minio   # replace APP_NAME with your namespace (e.g. app)
  namespace: APP_NAME    # replace APP_NAME with your namespace (e.g. app)
type: Opaque
stringData:
  root-user: "CHANGE_ME"       # min. 3 chars
  root-password: "CHANGE_ME"   # min. 8 chars
