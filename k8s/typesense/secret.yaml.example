# APP_NAME = the namespace / app prefix you chose during bootstrap (e.g. "app")
# kubectl create secret generic ${APP_NAME}-typesense \
#   --from-literal=api-key=CHANGE_ME \
#   --namespace=${APP_NAME}
# (bootstrap.sh handles this automatically)
apiVersion: v1
kind: Secret
metadata:
  name: APP_NAME-typesense   # replace APP_NAME with your namespace (e.g. app)
  namespace: APP_NAME        # replace APP_NAME with your namespace (e.g. app)
type: Opaque
stringData:
  api-key: "CHANGE_ME"
