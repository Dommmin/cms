# GlitchTip secrets — copy to secret.yaml (gitignored) and fill in.
#
#   cp k8s/glitchtip/secret.yaml.example k8s/glitchtip/secret.yaml
#   # edit k8s/glitchtip/secret.yaml, then bootstrap.sh applies it (or:)
#   kubectl apply -f k8s/glitchtip/secret.yaml
#
# One Secret, three keys — consumed by:
#   - SECRET_KEY        → glitchtip.existingSecret           (Helm values)
#   - POSTGRES_PASSWORD → k8s/glitchtip/postgresql.yaml      (StatefulSet env)
#   - DATABASE_URL      → glitchtip.database.existingSecret  (Helm values)
#
# DATABASE_URL format (the password MUST match POSTGRES_PASSWORD above):
#   postgres://glitchtip:<POSTGRES_PASSWORD>@glitchtip-postgresql:5432/glitchtip
apiVersion: v1
kind: Secret
metadata:
  name: glitchtip-secrets
  namespace: glitchtip
type: Opaque
stringData:
  # openssl rand -hex 25   →  50-char hex string
  SECRET_KEY: "CHANGE_ME_random_50_char_hex"

  # openssl rand -base64 24 | tr -d '/+='   →  strong password, no URL-unsafe chars
  POSTGRES_PASSWORD: "CHANGE_ME_strong_db_password"

  # Same password as POSTGRES_PASSWORD, embedded in the connection URL.
  # Host = the headless service from postgresql.yaml.
  DATABASE_URL: "postgres://glitchtip:CHANGE_ME_strong_db_password@glitchtip-postgresql:5432/glitchtip"
