# app = the namespace / app prefix you chose during bootstrap (e.g. "app")
# kubectl create secret generic ${app}-redis \
#   --from-literal=password=CHANGE_ME \
#   --namespace=${app}
# (bootstrap.sh handles this automatically)
apiVersion: v1
kind: Secret
metadata:
  name: app-redis   # replace app with your namespace (e.g. app)
  namespace: app    # replace app with your namespace (e.g. app)
type: Opaque
stringData:
  password: "CHANGE_ME"
