# APP_NAME = resource prefix; KUBE_NAMESPACE = namespace. Defaults are both "app".
# kubectl create secret generic ${APP_NAME}-mysql \
#   --from-literal=root-password=CHANGE_ME \
#   --from-literal=username=CHANGE_ME \
#   --from-literal=password=CHANGE_ME \
#   --namespace=${KUBE_NAMESPACE}
# (bootstrap.sh handles this automatically)
apiVersion: v1
kind: Secret
metadata:
  name: ${APP_NAME}-mysql
  namespace: ${KUBE_NAMESPACE}
type: Opaque
stringData:
  root-password: "CHANGE_ME"
  username: "CHANGE_ME"
  password: "CHANGE_ME"
