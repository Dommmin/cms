# app = the namespace / app prefix you chose during bootstrap (e.g. "app")
# kubectl create secret generic ${app}-mysql \
#   --from-literal=root-password=CHANGE_ME \
#   --from-literal=username=CHANGE_ME \
#   --from-literal=password=CHANGE_ME \
#   --namespace=${app}
# (bootstrap.sh handles this automatically)
apiVersion: v1
kind: Secret
metadata:
  name: app-mysql   # replace app with your namespace (e.g. app)
  namespace: app    # replace app with your namespace (e.g. app)
type: Opaque
stringData:
  root-password: "CHANGE_ME"
  username: "CHANGE_ME"
  password: "CHANGE_ME"
