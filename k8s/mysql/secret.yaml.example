# APP_NAME = the namespace / app prefix you chose during bootstrap (e.g. "app")
# kubectl create secret generic ${APP_NAME}-mysql \
#   --from-literal=root-password=CHANGE_ME \
#   --from-literal=username=CHANGE_ME \
#   --from-literal=password=CHANGE_ME \
#   --namespace=${APP_NAME}
# (bootstrap.sh handles this automatically)
apiVersion: v1
kind: Secret
metadata:
  name: APP_NAME-mysql   # replace APP_NAME with your namespace (e.g. app)
  namespace: APP_NAME    # replace APP_NAME with your namespace (e.g. app)
type: Opaque
stringData:
  root-password: "CHANGE_ME"
  username: "CHANGE_ME"
  password: "CHANGE_ME"
