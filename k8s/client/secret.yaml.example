# APP_NAME = the namespace / app prefix you chose during bootstrap (e.g. "app")
# NEXT_PUBLIC_* vars are baked at build time (--build-arg in CI via ENV_CLIENT_PROD variable).
# Runtime-only vars (not exposed to browser) go here.
#
#   APP_NAME=app
#   kubectl create secret generic ${APP_NAME}-client-env \
#     --from-literal=API_URL=http://${APP_NAME}-server.${APP_NAME}.svc.cluster.local/api/v1 \
#     --namespace=${APP_NAME}
apiVersion: v1
kind: Secret
metadata:
  name: APP_NAME-client-env   # replace APP_NAME with your namespace (e.g. app)
  namespace: APP_NAME         # replace APP_NAME with your namespace (e.g. app)
type: Opaque
stringData:
  # Internal API URL (server-side Next.js fetches — bypasses public internet)
  API_URL: "http://APP_NAME-server.APP_NAME.svc.cluster.local/api/v1"
