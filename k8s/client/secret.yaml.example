# NEXT_PUBLIC_* vars are baked at build time (--build-arg in CI), including
# NEXT_PUBLIC_GLITCHTIP_DSN for browser-side event capture.
# Runtime-only vars (not exposed to browser) go here.
#
#   kubectl create secret generic cms-client-env \
#     --from-literal=API_URL=http://cms-server.cms-prod.svc.cluster.local/api/v1 \
#     --namespace=cms-prod
apiVersion: v1
kind: Secret
metadata:
  name: cms-client-env
  namespace: cms-prod
type: Opaque
stringData:
  # Internal API URL (server-side Next.js fetches — bypasses public internet)
  API_URL: "http://cms-server.cms-prod.svc.cluster.local/api/v1"
