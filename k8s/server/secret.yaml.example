# =============================================================================
# Create the secret from your production .env file:
#
#   kubectl create secret generic cms-server-env \
#     --from-file=.env=server/.env.production \
#     --namespace=cms-prod \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# To update after a change:
#   kubectl create secret generic cms-server-env \
#     --from-file=.env=server/.env.production \
#     --namespace=cms-prod \
#     --dry-run=client -o yaml | kubectl apply -f -
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: cms-server-env
  namespace: cms-prod
type: Opaque
stringData:
  .env: |
    APP_NAME="CMS"
    APP_ENV=production
    APP_KEY=base64:CHANGE_ME_php_artisan_key_generate
    APP_DEBUG=false
    APP_URL=https://api.yourdomain.com
    FRONTEND_URL=https://yourdomain.com

    LOG_CHANNEL=stderr
    LOG_LEVEL=warning

    DB_CONNECTION=mysql
    DB_HOST=CHANGE_ME
    DB_PORT=3306
    DB_DATABASE=cms
    DB_USERNAME=CHANGE_ME
    DB_PASSWORD=CHANGE_ME

    REDIS_HOST=CHANGE_ME
    REDIS_PORT=6379
    REDIS_PASSWORD=CHANGE_ME

    SESSION_DRIVER=redis
    CACHE_STORE=redis
    QUEUE_CONNECTION=redis

    FILESYSTEM_DISK=s3
    AWS_ACCESS_KEY_ID=CHANGE_ME
    AWS_SECRET_ACCESS_KEY=CHANGE_ME
    AWS_DEFAULT_REGION=eu-central-1
    AWS_BUCKET=CHANGE_ME
    AWS_URL=https://CHANGE_ME.s3.eu-central-1.amazonaws.com

    MAIL_MAILER=smtp
    MAIL_HOST=CHANGE_ME
    MAIL_PORT=587
    MAIL_ENCRYPTION=tls
    MAIL_USERNAME=CHANGE_ME
    MAIL_PASSWORD=CHANGE_ME
    MAIL_FROM_ADDRESS=noreply@yourdomain.com
    MAIL_FROM_NAME="${APP_NAME}"

    SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com

    # Payments
    PAYU_CLIENT_ID=CHANGE_ME
    PAYU_CLIENT_SECRET=CHANGE_ME
    PAYU_POS_ID=CHANGE_ME
    PAYU_SECOND_KEY=CHANGE_ME
    PAYU_SANDBOX=false

    P24_MERCHANT_ID=CHANGE_ME
    P24_POS_ID=CHANGE_ME
    P24_CRC=CHANGE_ME
    P24_API_KEY=CHANGE_ME
    P24_SANDBOX=false

    # Cloudflare Turnstile
    TURNSTILE_SITE_KEY=CHANGE_ME
    TURNSTILE_SECRET_KEY=CHANGE_ME

    # PDF (Gotenberg — deploy separately or use SaaS)
    PDF_DRIVER=gotenberg
    GOTENBERG_URL=http://gotenberg:3000

    # Social login
    GOOGLE_CLIENT_ID=CHANGE_ME
    GOOGLE_CLIENT_SECRET=CHANGE_ME
    GITHUB_CLIENT_ID=CHANGE_ME
    GITHUB_CLIENT_SECRET=CHANGE_ME
