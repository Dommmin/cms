# =============================================================================
# Production Environment — copy to .env.prod and fill in your values
#
# IMPORTANT: Never commit .env.prod to source control.
# =============================================================================

# ── Blue-Green State ──────────────────────────────────────────────────────────
# Managed by scripts/deploy.sh — set the initial value manually
ACTIVE_SLOT=blue
APP_VERSION=latest

# ── GitHub Container Registry ────────────────────────────────────────────────
# Used by docker-compose.prod.yml to pull images
# Example: myorg/my-repo  (without ghcr.io/ prefix)
GITHUB_REPOSITORY=your-org/cms

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:CHANGE_ME
APP_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cms
DB_USERNAME=cms_user
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Your App"

# ── Typesense ────────────────────────────────────────────────────────────────
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=CHANGE_ME

# ── Storage (local or S3) ────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# AWS_BUCKET=

# ── Next.js Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_APP_NAME="Your App"

# ── Ports (host-side) ─────────────────────────────────────────────────────────
HTTP_PORT=80
FRONTEND_PORT=3000
