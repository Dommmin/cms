# =============================================================================
# Build-time environment for Docker image assembly.
# Used ONLY during `npm run build` (Vite admin SPA compilation).
# Does NOT contain real production secrets.
#
# Real production secrets live in k8s/server/secret.yaml
# and are mounted at runtime as /var/www/html/.env inside the pod.
# =============================================================================

APP_NAME="CMS"
APP_ENV=production
APP_KEY=base64:build-time-placeholder-replaced-at-runtime-by-k8s-secret
APP_DEBUG=false
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cms
DB_USERNAME=cms
DB_PASSWORD=build-only-not-used-at-runtime

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=build-only-not-used-at-runtime

SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=build-only
AWS_SECRET_ACCESS_KEY=build-only
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=build-only

SCOUT_DRIVER=typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=build-only-not-used-at-runtime
