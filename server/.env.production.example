# =============================================================================
# Production .env template
#
# This file is committed to the repository with EMPTY secret values.
# It documents every variable the app needs in production.
#
# How to use:
#   1. Copy this file, fill in all empty values
#   2. Paste the full content into the GitHub Variable PROD_ENV
#      (Settings → Secrets and variables → Actions → Variables)
#   3. The CI/CD pipeline syncs PROD_ENV to a Kubernetes Secret on every deploy
#
# AI rule: when adding a package that requires new env variables, add them here.
# =============================================================================

APP_NAME="CMS"
APP_ENV=production
APP_KEY=                                        # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=cms-mysql.cms-prod.svc.cluster.local   # k8s internal DNS
DB_PORT=3306
DB_DATABASE=cms
DB_USERNAME=cms
DB_PASSWORD=

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=cms-redis.cms-prod.svc.cluster.local  # k8s internal DNS
REDIS_PASSWORD=
REDIS_PORT=6379

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── Storage (S3 / Cloudflare R2) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_URL=                                        # https://BUCKET.s3.REGION.amazonaws.com
                                                # or R2 public URL: https://pub-xxx.r2.dev
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Modules ──────────────────────────────────────────────────────────────────
MODULE_BLOG=true
MODULE_ECOMMERCE=true
MODULE_NEWSLETTER=true
MODULE_MARKETING=true

# ─── Media Library ────────────────────────────────────────────────────────────
MEDIA_DISK=s3
IMAGE_DRIVER=gd
MEDIA_QUEUE=media-conversions
QUEUE_CONVERSIONS_BY_DEFAULT=false
QUEUE_CONVERSIONS_AFTER_DB_COMMIT=false

# ─── PDF Generation (Gotenberg) ───────────────────────────────────────────────
LARAVEL_PDF_DRIVER=gotenberg
GOTENBERG_URL=http://cms-gotenberg.cms-prod.svc.cluster.local:3000

# ─── Typesense Search ─────────────────────────────────────────────────────────
SCOUT_DRIVER=typesense
SCOUT_QUEUE=true
TYPESENSE_HOST=cms-typesense.cms-prod.svc.cluster.local  # k8s internal DNS
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=

# ─── Sanctum ──────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com
SANCTUM_TOKEN_EXPIRATION=43200                  # 30 days

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Inertia ──────────────────────────────────────────────────────────────────
INERTIA_SSR_ENABLED=false
INERTIA_ENCRYPT_HISTORY=false

# ─── Apple Pay ────────────────────────────────────────────────────────────────
APPLE_PAY_MERCHANT_ID=
APPLE_PAY_CERT_PATH=
APPLE_PAY_KEY_PATH=

# ─── Web Push Notifications (VAPID) ──────────────────────────────────────────
# Generate with: php artisan vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Error Tracking (GlitchTip — Sentry SDK compatible) ──────────────────────
GLITCHTIP_DSN=
GLITCHTIP_SAMPLE_RATE=1.0
GLITCHTIP_TRACES_SAMPLE_RATE=0.2
GLITCHTIP_PROFILES_SAMPLE_RATE=0.2
GLITCHTIP_SEND_DEFAULT_PII=false

# ─── Health Checks & Monitoring ───────────────────────────────────────────────
# Secret token required in X-Secret-Token header to access /health endpoint.
HEALTH_SECRET_TOKEN=
# HEALTH_SLACK_WEBHOOK_URL=

# ─── Note ─────────────────────────────────────────────────────────────────────
# PayU, P24, bank transfer, Furgonetka, InPost, social login (Google/GitHub),
# and Cloudflare Turnstile credentials are configured via the admin panel
# under Settings → Payments / Shipping / Integrations.
# They are stored in the database — no env variables needed here.
