{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "docker",
                "compose",
                "exec",
                "-T",
                "php",
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "shadcn": {
            "type": "local",
            "command": [
                "npx",
                "shadcn@latest",
                "mcp"
            ],
            "enabled": true
        }
    }
}