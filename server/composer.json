{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/react-starter-kit",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "dedoc/scramble": "^0.13.14",
        "gusapi/gusapi": "^3.3",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/ai": "^0.3.1",
        "laravel/fortify": "^1.30",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.24",
        "laravel/socialite": "^5.24",
        "laravel/telescope": "^5.17",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.9",
        "maatwebsite/excel": "^3.1",
        "sentry/sentry-laravel": "^4.24",
        "spatie/image-optimizer": "^1.8",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-data": "^4.19",
        "spatie/laravel-health": "^1.39",
        "spatie/laravel-medialibrary": "^11.19",
        "spatie/laravel-model-states": "^2.13",
        "spatie/laravel-pdf": "^2.2",
        "spatie/laravel-permission": "^7.0",
        "spatie/laravel-query-builder": "^6.4",
        "spatie/laravel-sitemap": "^7.3",
        "spatie/laravel-sluggable": "^3.7",
        "spatie/laravel-translatable": "^6.12",
        "typesense/typesense-php": "^6.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "dompdf/dompdf": "^3.1",
        "driftingly/rector-laravel": "^2.0",
        "fakerphp/faker": "^1.23",
        "fruitcake/laravel-debugbar": "^4.1",
        "larastan/larastan": "^3.7",
        "laravel/boost": "^2.3",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.0",
        "rector/rector": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "lint": [
            "rector",
            "pint"
        ],
        "test:lint": [
            "rector --dry-run",
            "pint --test"
        ],
        "test:types": [
            "phpstan"
        ],
        "test:unit": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ],
        "larastan": "./vendor/bin/phpstan analyse --memory-limit=2G",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
