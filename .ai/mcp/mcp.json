{
  "mcpServers": {
    "laravel-boost": {
      "command": "docker",
      "args": [
        "compose",
        "exec",
        "-T",
        "php",
        "php",
        "artisan",
        "boost:mcp"
      ]
    }
  },
  "shadcn": {
    "command": "npx",
    "args": [
      "shadcn@latest",
      "mcp"
    ]}
  }
}
